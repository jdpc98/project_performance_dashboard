from dash import Input, Output, State, callback
from dash.exceptions import PreventUpdate
from src.data_manager import load_data, cache_data

@callback(
    Output('output-container', 'children'),
    Input('submit-button', 'n_clicks'),
    State('input-field', 'value')
)
def update_output(n_clicks, input_value):
    if n_clicks is None:
        raise PreventUpdate

    # Load data from cache or database
    data = load_data(input_value)
    
    if data is None:
        return "No data found for the given input."
    
    # Cache the data if necessary
    cache_data(input_value, data)

    return f"Data for {input_value}: {data}"

